@page "/about"
@using Microsoft.AspNetCore.Components

<div id="constellationContainer">
    <canvas id="constellationCanvas"></canvas>
</div>

<div class="about-page">
    <h1>About</h1>

    <p>
        <a href="/">Return to Esmeralda</a>
    </p>

    <p>
        Esmeralda Foretells is where intuition meets enchantment. Born from a love of mystical storytelling and the quiet magic of tarot, Esmeralda is your guide through the unseen threads that shape your path.
    </p>

    <p>
        Each reading is an invitation — to pause, to reflect, to rediscover the wisdom that whispers beneath the noise of everyday life. Esmeralda Foretells blends evocative imagery, gentle interpretation, and a touch of the arcane to create an experience that feels personal, soulful, and beautifully immersive.
    </p>

    <p>
        For dreamers, seekers, and anyone drawn to the mysteries of the cards, Esmeralda Foretells offers a space to explore your journey with wonder and intention.
    </p>
    <ul>
        <li>Tarot Cards by A.Prozo https://creativemarket.com/A.Prozo</li>
        <li>Card selection using our own arcane algorithm</li>
        <li>Programming and Prompt by Mike</li>
        <li>Visualisation by Danielle</li>
        <li>A Razor page using .Net Core</li>
        <li>The eloquent Large Language Model DeepSeek-V4-Flash providing insight into the cards</li>
        <li>Tested on human beings and found to be as insightful and uplifting as designed</li>
    </ul>
</div>

<script>
    window.zodiacConstellations = window.zodiacConstellations || [
        { name: 'Aries', stars: [{x:0.12,y:0.18},{x:0.18,y:0.22},{x:0.22,y:0.20}], lines: [[0,1],[1,2]] },
        { name: 'Taurus', stars: [{x:0.30,y:0.12},{x:0.34,y:0.18},{x:0.38,y:0.14},{x:0.42,y:0.22}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Gemini', stars: [{x:0.55,y:0.10},{x:0.58,y:0.16},{x:0.62,y:0.12},{x:0.64,y:0.20}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Cancer', stars: [{x:0.82,y:0.16},{x:0.85,y:0.22},{x:0.88,y:0.18}], lines: [[0,1],[1,2]] },
        { name: 'Leo', stars: [{x:0.18,y:0.42},{x:0.22,y:0.48},{x:0.24,y:0.42},{x:0.28,y:0.50}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Virgo', stars: [{x:0.41,y:0.36},{x:0.45,y:0.43},{x:0.49,y:0.39},{x:0.52,y:0.46}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Libra', stars: [{x:0.70,y:0.40},{x:0.74,y:0.46},{x:0.78,y:0.42}], lines: [[0,1],[1,2]] },
        { name: 'Scorpio', stars: [{x:0.84,y:0.38},{x:0.88,y:0.44},{x:0.92,y:0.39},{x:0.96,y:0.46}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Sagittarius', stars: [{x:0.15,y:0.75},{x:0.20,y:0.80},{x:0.25,y:0.74},{x:0.30,y:0.82}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Capricorn', stars: [{x:0.40,y:0.68},{x:0.44,y:0.74},{x:0.48,y:0.70}], lines: [[0,1],[1,2]] },
        { name: 'Aquarius', stars: [{x:0.60,y:0.72},{x:0.64,y:0.78},{x:0.68,y:0.74},{x:0.72,y:0.80}], lines: [[0,1],[1,2],[2,3]] },
        { name: 'Pisces', stars: [{x:0.80,y:0.68},{x:0.84,y:0.74},{x:0.88,y:0.70}], lines: [[0,1],[1,2]] }
    ];

    function setupConstellationCanvas() {
        const canvas = document.getElementById('constellationCanvas');
        const parent = document.getElementById('constellationContainer');
        if (!canvas || !parent) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        function resize() {
            const dpr = window.devicePixelRatio || 1;
            const width = parent.clientWidth;
            const height = parent.clientHeight;
            canvas.style.width = width + 'px';
            canvas.style.height = height + 'px';
            canvas.width = Math.floor(width * dpr);
            canvas.height = Math.floor(height * dpr);
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            draw();
        }

        function draw() {
            const width = parent.clientWidth;
            const height = parent.clientHeight;
            ctx.clearRect(0, 0, width, height);
            ctx.strokeStyle = 'rgba(255,255,255,0.22)';
            ctx.fillStyle = 'rgba(255,255,255,0.9)';
            ctx.lineWidth = 1;

            window.zodiacConstellations.forEach(constellation => {
                constellation.lines.forEach(([a, b]) => {
                    const from = constellation.stars[a];
                    const to = constellation.stars[b];
                    ctx.beginPath();
                    ctx.moveTo(from.x * width, from.y * height);
                    ctx.lineTo(to.x * width, to.y * height);
                    ctx.stroke();
                });

                constellation.stars.forEach(star => {
                    const x = star.x * width;
                    const y = star.y * height;
                    ctx.beginPath();
                    ctx.arc(x, y, 2.5, 0, Math.PI * 2);
                    ctx.fill();
                });
            });
        }

        window.addEventListener('resize', resize);
        resize();
    }

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        setupConstellationCanvas();
    } else {
        window.addEventListener('load', setupConstellationCanvas);
    }
</script>
